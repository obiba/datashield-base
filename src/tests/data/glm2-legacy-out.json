              "                \"binomial\"), domain = NA)",
              "        n <- (y1 <- y[, 1L]) + y[, 2L]",
              "        y <- y1/n",
              "        if (any(n0 <- n == 0)) ",
              "            y[n0] <- 0",
              "        weights <- weights * n",
              "        mustart <- (n * y + 0.5)/(n + 1)",
